# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成し、値を編集してください。
# terraform.tfvars は機密情報を含みうるため Git にコミットしないこと（.gitignore 済み）。
#
#   cp infra/terraform.tfvars.example infra/terraform.tfvars

aws_region = "ap-northeast-1"

# 未指定なら "<AccountId>-<Region>" が自動的に使われる
# bucket_name_suffix = "123456789012-ap-northeast-1"

email_subscription = "your@email.com"

# Lambda関数デプロイ後に取得したARNを指定する（デプロイ手順は docs/deployment.md 参照）
lambda_function_arn = "arn:aws:lambda:ap-northeast-1:123456789012:function:security-hub-agent"

# AgentCore Runtime 用コンテナイメージのタグ（ECRにpush済みのタグを指定する）
# agent_image_tag = "latest"

# AgentCore Runtime上のAgentが使用するBedrockモデルID
# bedrock_model_id = "global.anthropic.claude-sonnet-4-6"

# true: 実際の修復を行わない（レポート生成・通知のみ） / false: 本番実行
# dry_run = true
